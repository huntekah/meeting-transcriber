# LLM Intelligence Service — Environment Variables
# Copy to .env and fill in your values.

# Default LLM model. Prefix "gemini" → Gemini API. Anything else → Ollama.
LLM_MODEL=gemini-2.5-flash

# Gemini API key (required for Gemini models)
GEMINI_API_KEY=your-gemini-api-key-here

# VertexAI alternative (set GEMINI_API_KEY OR these three)
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=europe-west1
# GOOGLE_GENAI_USE_VERTEXAI=true

# Ollama host (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Path to skills directory (default: skills/ relative to working dir)
# SKILLS_DIR=skills
